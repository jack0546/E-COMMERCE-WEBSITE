rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'narhsnazzisco@gmail.com';
    }

    // Public product catalog - read-only for everyone
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin(); // Only allow the admin to add/edit products
    }
    
    // User profiles - each user manages their own
    match /users/{userId} {
      // Users can read/write their own profile, OR the admin can read/write all profiles
      // Updated to handle the new "Country" field in profiles
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }
    
    // User wishlists/saved items
    match /users/{userId}/wishlist/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Orders - handles the new tabular order data and "Mark as Read" status
    match /orders/{orderId} {
      // User can view their own orders, Admin can view all orders
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId) || isAdmin();
      
      // User can create an order with the new granular fields (contact, location, country, isNew)
      allow create: if request.auth != null && 
                    request.auth.uid == request.resource.data.userId;
                    
      // Only admin can update an order.
      // THIS RULE ALLOWS THE "MARK AS READ" BUTTON TO WORK
      allow update: if isAdmin();
      
      // Prevent deletion for audit/record purposes
      allow delete: if false; 
    }
    
    // General Admin catch-all
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
